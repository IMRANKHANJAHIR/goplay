<!DOCTYPE html>
<html>
<head>
<title>Tic Tac Toe</title>

<style>
body{
  background:#111;
  color:white;
  text-align:center;
  font-family:Arial;
}

.board{
  width:300px;
  margin:auto;
  display:grid;
  grid-template-columns:repeat(3,100px);
}

.cell{
  width:100px;
  height:100px;
  background:#222;
  border:2px solid #333;
  font-size:50px;
  cursor:pointer;

  display:flex;
  justify-content:center;
  align-items:center;
}
</style>
</head>

<body>

<h1>❌ Tic Tac Toe ⭕</h1>

<div class="board">

    <div class="cell"></div>
    <div class="cell"></div>
    <div class="cell"></div>
  
    <div class="cell"></div>
    <div class="cell"></div>
    <div class="cell"></div>
  
    <div class="cell"></div>
    <div class="cell"></div>
    <div class="cell"></div>
  
  </div>

<button onclick="location.reload()">
    🔄 Play Again
  </button>
  
  <a href="/dashboard">
    <button>
      🏠 Dashboard
    </button>
  </a>
  

  <script>
    let gameOver = false;
    
    const cells = document.querySelectorAll(".cell");
    
    async function rewardCoins(coins) {
    
        try{
    
            await fetch("/reward",{
    
                method:"POST",
    
                headers:{
                    "Content-Type":"application/json"
                },
    
                body:JSON.stringify({
                    coins:coins
                })
    
            });
    
        }catch(err){
            console.log(err);
        }
    
    }
    
    function checkWinner(player){
    
        const board=[];
    
        cells.forEach(cell=>board.push(cell.innerHTML));
    
        const wins=[
            [0,1,2],[3,4,5],[6,7,8],
            [0,3,6],[1,4,7],[2,5,8],
            [0,4,8],[2,4,6]
        ];
    
        for(let combo of wins){
    
            const[a,b,c]=combo;
    
            if(
                board[a]===player &&
                board[b]===player &&
                board[c]===player
            ){
    
                gameOver=true;
    
                if(player==="X"){
                    rewardCoins(10);
                }
    
                setTimeout(()=>{
    
                    if(player==="X"){
                        alert("🎉 You Won! +10 Coins");
                    }else{
                        alert("😢 Computer Won");
                    }
    
                },100);
    
                return true;
            }
    
        }
    
        if(!board.includes("")){
    
            gameOver=true;
    
            rewardCoins(2);
    
            setTimeout(()=>{
                alert("🤝 Draw! +2 Coins");
            },100);
    
            return true;
    
        }
    
        return false;
    
    }
    
    function computerMove(){
    
        if(gameOver) return;
    
        const empty=[];
    
        cells.forEach((cell,index)=>{
    
            if(cell.innerHTML===""){
                empty.push(index);
            }
    
        });
    
        if(empty.length===0) return;
    
        const random=empty[Math.floor(Math.random()*empty.length)];
    
        cells[random].innerHTML="O";
    
        checkWinner("O");
    
    }
    
    cells.forEach(cell=>{
    
        cell.addEventListener("click",()=>{
    
            if(gameOver) return;
    
            if(cell.innerHTML!=="") return;
    
            cell.innerHTML="X";
    
            if(checkWinner("X")) return;
    
            setTimeout(computerMove,500);
    
        });
    
    });
    </script>

</body>
</html>